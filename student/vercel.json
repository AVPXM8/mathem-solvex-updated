{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/robots.txt",
      "destination": "https://mathemsolvex.onrender.com/robots.txt"
    },
    {
      "source": "/sitemap.xml",
      "destination": "https://mathemsolvex.onrender.com/sitemap.xml"
    },
    {
      "source": "/question/:id",
      "destination": "/api/og-question?id=:id"
    },
    {
      "source": "/((?!api|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
